rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().get('isAdmin', false) == true;
    }
    
    function isInsAdmin() {
      return isSignedIn() && getUserData().get('isinsadmin', false) == true;
    }
    
    function isInsAdminFor(instituteId) {
      return isInsAdmin() && getUserData().get('instituteId', '') == instituteId;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && isOwner(userId)) || isInsAdminFor(request.resource.data.get('instituteId', ''));
      allow delete: if isAdmin() || isInsAdminFor(resource.data.get('instituteId', '')) || (isSignedIn() && isOwner(userId));
      allow update: if isAdmin() || 
                    isInsAdminFor(resource.data.get('instituteId', '')) || 
                    isInsAdminFor(request.resource.data.get('instituteId', '')) ||
                    (isSignedIn() && isOwner(userId)) ||
                    isSignedIn(); // Broad update for connection requests
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAdmin() || isInsAdminFor(request.resource.data.get('instituteId', ''));
      allow update: if isSignedIn() || isAdmin() || isInsAdminFor(resource.data.get('instituteId', ''));
      allow delete: if isAdmin() || 
                    isInsAdminFor(resource.data.get('instituteId', '')) ||
                    (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ── Opportunities (Jobs board) ────────────────────────────────────────────
    match /opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAdmin() || isInsAdminFor(request.resource.data.get('instituteId', ''));
      allow update: if isAdmin() ||
                    isInsAdminFor(resource.data.get('instituteId', '')) ||
                    isInsAdminFor(request.resource.data.get('instituteId', '')) ||
                    (isSignedIn() && resource.data.postedByUid == request.auth.uid);
      allow delete: if isAdmin() ||
                    isInsAdminFor(resource.data.get('instituteId', '')) ||
                    (isSignedIn() && resource.data.postedByUid == request.auth.uid);
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
        (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
    }

    // ── Groups ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
        (resource == null || request.auth.uid in resource.data.members);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.members;
    }

    // ── Subcollections (Messages) ─────────────────────────────────────────────
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }
    match /groups/{groupId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }
    match /communityChat/{messageId} {
      allow read, create: if isSignedIn();
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAdmin() || isInsAdminFor(request.resource.data.get('instituteId', ''));
      allow update, delete: if isAdmin() ||
                            isInsAdminFor(resource.data.get('instituteId', '')) ||
                            (isSignedIn() && resource.data.createdByUid == request.auth.uid);
    }

    // ── Institutes ────────────────────────────────────────────────────────────
    match /institutes/{instId} {
      allow read: if true;
      allow write: if isAdmin() || isInsAdminFor(instId);
    }

    // ── Email Approvals ───────────────────────────────────────────────────────
    match /approvals/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
