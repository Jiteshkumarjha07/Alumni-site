rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isParticipant(chatId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    function isGroupMember(groupId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read all users (needed for search / profile pages).
    // Any signed-in user can update any user document (needed for connection
    //   requests that push to another user's connections array).
    // Only the owner can create/delete their document.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn();
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    // Any member can read and create posts.
    // Any member can UPDATE a post (likes, comments use arrayUnion on other users' posts).
    // Only the author can DELETE their post.
    match /posts/{postId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── Opportunities (Jobs board) ────────────────────────────────────────────
    match /opportunities/{oppId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.postedByUid == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Users can only read their own notifications; anyone can create one
    // (needed when user A likes/connects and writes a notification for user B).
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    // IMPORTANT: On a COLLECTION QUERY (list), resource is null — you cannot
    // check resource.data.participants in a list rule. Instead allow list for
    // any authenticated user and rely on the where('participants','array-contains',uid)
    // query filter. Individual document reads/writes verify participation.
    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
        (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
    }

    // ── Chat Messages Subcollection ───────────────────────────────────────────
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isParticipant(chatId);
      allow create: if isSignedIn();
    }

    // ── Groups ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
        (resource == null || request.auth.uid in resource.data.members);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.members;
    }

    // ── Group Messages Subcollection ──────────────────────────────────────────
    // Was MISSING in previous rules — caused all group chat writes to fail.
    match /groups/{groupId}/messages/{messageId} {
      allow read, write: if isGroupMember(groupId);
      allow create: if isSignedIn();
    }

    // ── Community Chat ────────────────────────────────────────────────────────
    match /communityChat/{messageId} {
      allow read, create: if isSignedIn();
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;
    }

    // ── Institutes ────────────────────────────────────────────────────────────
    // Public read (signup needs institute list before auth).
    match /institutes/{instId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Email Approvals ───────────────────────────────────────────────────────
    // Public read for signup domain validation.
    match /approvals/{email} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
